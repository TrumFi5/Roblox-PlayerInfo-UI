-- CHỨC NĂNG 1: RACE V4 (Nút Hồng Cam)
-- ==========================================
CreateMenuButton("RaceV4Btn", "🦄 Race V4", Color3.fromRGB(240, 98, 146), function()
    -- XÓA MENU BAN ĐẦU NGAY LẬP TỨC[cite: 2]
    ScreenGui:Destroy()

    -- Thực thi code Race V4 của bạn[cite: 2]
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")

    local Player = Players.LocalPlayer
    local PlayerGui = Player:WaitForChild("PlayerGui")

    local old = PlayerGui:FindFirstChild("PlayerInfoUI")
    if old then old:Destroy() end

    local Gui = Instance.new("ScreenGui")
    Gui.Name = "PlayerInfoUI"
    Gui.ResetOnSpawn = false
    Gui.Parent = PlayerGui

    local ToggleBtnV4 = Instance.new("TextButton")
    ToggleBtnV4.Parent = Gui
    ToggleBtnV4.Size = UDim2.new(0,70,0,30)
    ToggleBtnV4.Position = UDim2.new(0.5,-35,0.02,0)
    ToggleBtnV4.BackgroundColor3 = Color3.fromRGB(255,105,180)
    ToggleBtnV4.TextColor3 = Color3.new(1,1,1)
    ToggleBtnV4.Font = Enum.Font.GothamBold
    ToggleBtnV4.TextSize = 16
    ToggleBtnV4.Text = "ON"

    Instance.new("UICorner", ToggleBtnV4).CornerRadius = UDim.new(0,8)

    local FrameV4 = Instance.new("Frame")
    FrameV4.Parent = Gui
    FrameV4.Size = UDim2.new(0,320,0,125)
    FrameV4.Position = UDim2.new(0.5,-160,0.08,0)
    FrameV4.BackgroundColor3 = Color3.fromRGB(255,192,203)
    FrameV4.BackgroundTransparency = 0.2
    FrameV4.BorderSizePixel = 0

    Instance.new("UICorner", FrameV4).CornerRadius = UDim.new(0,12)

    local StrokeV4 = Instance.new("UIStroke")
    StrokeV4.Parent = FrameV4
    StrokeV4.Color = Color3.fromRGB(255,20,147)
    StrokeV4.Thickness = 2

    local function CreateLabel(text,y)
        local L = Instance.new("TextLabel")
        L.Parent = FrameV4
        L.BackgroundTransparency = 1
        L.Size = UDim2.new(1,-20,0,20)
        L.Position = UDim2.new(0,10,0,y)
        L.Font = Enum.Font.GothamBold
        L.TextSize = 16
        L.TextColor3 = Color3.new(1,1,1)
        L.TextXAlignment = Enum.TextXAlignment.Left
        L.Text = text
        return L
    end

    CreateLabel("Name: "..Player.DisplayName,10)
    CreateLabel("Username: @"..Player.Name,35)
    local Race = CreateLabel("Race: Unknown",60)
    local FPS = CreateLabel("FPS: 0",85)

    local Frames = 0
    local Last = tick()
    local Hue = 0

    local renderConn
    renderConn = RunService.RenderStepped:Connect(function(dt)
        if not Gui or not Gui.Parent then renderConn:Disconnect() return end
        Frames += 1
        Hue = (Hue + dt*0.25)%1
        FPS.TextColor3 = Color3.fromHSV(Hue,1,1)

        if tick()-Last >= 1 then
            FPS.Text = "FPS: "..Frames
            Frames = 0
            Last = tick()
        end
    end)

    task.spawn(function()
        while task.wait(1) do
            if not Gui or not Gui.Parent then break end
            pcall(function()
                local Data = Player:FindFirstChild("Data")
                if Data then
                    local race = Data:FindFirstChild("Race")
                    if race then Race.Text = "Race: "..tostring(race.Value) else Race.Text = "Race: Unknown" end
                else
                    Race.Text = "Race: Unknown"
                end
            end)
        end
    end)

    local VisibleV4 = true
    ToggleBtnV4.MouseButton1Click:Connect(function()
        VisibleV4 = not VisibleV4
        FrameV4.Visible = VisibleV4
        if VisibleV4 then
            ToggleBtnV4.Text = "ON"
            ToggleBtnV4.BackgroundColor3 = Color3.fromRGB(255,105,180)
        else
            ToggleBtnV4.Text = "OFF"
            ToggleBtnV4.BackgroundColor3 = Color3.fromRGB(120,120,120)
        end
    end)
end)

