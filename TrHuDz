local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

local old = PlayerGui:FindFirstChild("PlayerInfoUI")
if old then
	old:Destroy()
end

local Gui = Instance.new("ScreenGui")
Gui.Name = "PlayerInfoUI"
Gui.ResetOnSpawn = false
Gui.DisplayOrder = 999999
Gui.Parent = PlayerGui

local ToggleButton = Instance.new("TextButton")
ToggleButton.Parent = Gui
ToggleButton.Size = UDim2.new(0,70,0,30)
ToggleButton.Position = UDim2.new(0.5,-35,0.02,0)
ToggleButton.BackgroundColor3 = Color3.fromRGB(255,105,180)
ToggleButton.TextColor3 = Color3.new(1,1,1)
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.TextSize = 16
ToggleButton.Text = "ON"

Instance.new("UICorner", ToggleButton).CornerRadius = UDim.new(0,8)

local Frame = Instance.new("Frame")
Frame.Parent = Gui
Frame.Size = UDim2.new(0,320,0,125)
Frame.Position = UDim2.new(0.5,-160,0.08,0)
Frame.BackgroundColor3 = Color3.fromRGB(255,192,203)
Frame.BackgroundTransparency = 0.2
Frame.BorderSizePixel = 0

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0,12)

local Stroke = Instance.new("UIStroke")
Stroke.Parent = Frame
Stroke.Color = Color3.fromRGB(255,20,147)
Stroke.Thickness = 2

local function CreateLabel(text,y)
	local L = Instance.new("TextLabel")
	L.Parent = Frame
	L.BackgroundTransparency = 1
	L.Size = UDim2.new(1,-20,0,20)
	L.Position = UDim2.new(0,10,0,y)
	L.Font = Enum.Font.GothamBold
	L.TextSize = 16
	L.TextColor3 = Color3.new(1,1,1)
	L.TextXAlignment = Enum.TextXAlignment.Left
	L.Text = text
	return L
end

CreateLabel("Name: "..Player.DisplayName,10)
CreateLabel("Username: @"..Player.Name,35)
local Race = CreateLabel("Race: Unknown",60)
local FPS = CreateLabel("FPS: 0",85)

local Frames = 0
local Last = tick()
local Hue = 0

RunService.RenderStepped:Connect(function(dt)
	Frames += 1

	Hue = (Hue + dt*0.25)%1
	FPS.TextColor3 = Color3.fromHSV(Hue,1,1)

	if tick()-Last >= 1 then
		FPS.Text = "FPS: "..Frames
		Frames = 0
		Last = tick()
	end
end)

task.spawn(function()
	while task.wait(1) do
		pcall(function()
			local Data = Player:FindFirstChild("Data")

			if Data then
				local race = Data:FindFirstChild("Race")

				if race then
					Race.Text = "Race: "..tostring(race.Value)
				else
					Race.Text = "Race: Unknown"
				end
			else
				Race.Text = "Race: Unknown"
			end
		end)
	end
end)
local Visible = true

ToggleButton.MouseButton1Click:Connect(function()
	Visible = not Visible
	Frame.Visible = Visible

	if Visible then
		ToggleButton.Text = "ON"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(255,105,180)
	else
		ToggleButton.Text = "OFF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(120,120,120)
	end
end)
