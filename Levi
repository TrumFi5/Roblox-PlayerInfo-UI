-- 2. HỆ THỐNG GỌI REMOTE & QUÉT TÚI ĐỒ
-- ==========================================
local function getMaterialsFromGame()
	local inventory = {}
	
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	local commF = remotes and remotes:FindFirstChild("CommF_") or ReplicatedStorage:FindFirstChild("CommF_")
	
	if commF and commF:IsA("RemoteFunction") then
		local success, result = pcall(function()
			return commF:InvokeServer("getInventory")
		end)
		
		if success and type(result) == "table" then
			for _, item in pairs(result) do
				if item.Name then
					inventory[item.Name] = item.Count or item.Value or 1
				end
			end
		end
	end
	
	local data = LocalPlayer:FindFirstChild("Data")
	if data then
		for _, v in pairs(data:GetChildren()) do
			if v:IsA("ValueBase") then
				inventory[v.Name] = v.Value
			end
		end
		for _, folder in pairs(data:GetChildren()) do
			if folder:IsA("Folder") or folder:IsA("Configuration") then
				for _, v in pairs(folder:GetChildren()) do
					if v:IsA("ValueBase") then
						inventory[v.Name] = v.Value
					elseif v:IsA("Folder") then
						for _, subV in pairs(v:GetChildren()) do
							if subV:IsA("ValueBase") then
								inventory[subV.Name] = subV.Value
							end
						end
					end
				end
			end
		end
	end
	
	return inventory
end

local isRunning = true

local function UpdateMaterials()
	if not isRunning then return end
	local inv = getMaterialsFromGame()
	
	local function getItem(namesList)
		for _, name in pairs(namesList) do
			local cleanTarget = string.lower(name):gsub("%s+", "")
			for key, value in pairs(inv) do
				local cleanKey = string.lower(key):gsub("%s+", "")
				if cleanKey == cleanTarget or string.find(cleanKey, cleanTarget) then
					return tonumber(value) or 0
				end
			end
		end
		return 0
	end

	-- 1. Nguyên thạch (Dark Fragment)
	local darkFrag = getItem({"Dark Fragment", "DarkFragment"})
	lblNguyenthach.Text = darkFrag .. "/2"
	lblNguyenthach.TextColor3 = (darkFrag >= 2) and Color3.fromRGB(74, 222, 128) or Color3.fromRGB(239, 68, 68)

	-- 2. Răng nanh (Vampire Fang)
	local fang = getItem({"Vampire Fang", "VampireFang"})
	lblRangnanh.Text = fang .. "/20"
	lblRangnanh.TextColor3 = (fang >= 20) and Color3.fromRGB(74, 222, 128) or Color3.fromRGB(239, 68, 68)

	-- 3. Quỷ hồn (Demonic Wisp)
	local soul = getItem({"Demonic Wisp", "DemonicWisp", "Demonic Soul", "DemonicSould", "Quy Hon", "QuyHon"})
	lblQuyhon.Text = soul .. "/20"
	lblQuyhon.TextColor3 = (soul >= 20) and Color3.fromRGB(74, 222, 128) or Color3.fromRGB(239, 68, 68)

	-- 4. Trái Tim Leviathan (Leviathan Heart)
	local heart = getItem({"Leviathan Heart", "LeviathanHeart"})
	lblLeviathan.Text = heart .. "/1"
	lblLeviathan.TextColor3 = (heart >= 1) and Color3.fromRGB(74, 222, 128) or Color3.fromRGB(239, 68, 68)

	-- 5. Huyết Quỷ Thuật (Sanguine Art)
	local hasSanguine = false
	
	local sanguineVal = getItem({"Sanguine Art", "SanguineArt", "Sanguine"})
	if sanguineVal == true or sanguineVal == 1 or inv["Sanguine Art"] or inv["SanguineArt"] then
		hasSanguine = true
	end
	
	pcall(function()
		local backpack = LocalPlayer:FindFirstChild("Backpack")
		local character = LocalPlayer.Character
		
		if backpack then
			for _, tool in pairs(backpack:GetChildren()) do
				if string.find(string.lower(tool.Name), "sanguine") then
					hasSanguine = true
				end
			end
		end
		if character then
			for _, tool in pairs(character:GetChildren()) do
				if tool:IsA("Tool") and string.find(string.lower(tool.Name), "sanguine") then
					hasSanguine = true
				end
			end
			for _, v in pairs(character:GetDescendants()) do
				if v:IsA("StringValue") and string.find(string.lower(v.Value), "sanguine") then
					hasSanguine = true
				end
			end
		end
	end)

	if hasSanguine then
		lblHuyetquy.Text = "Đã có"
		lblHuyetquy.TextColor3 = Color3.fromRGB(74, 222, 128)
	else
		lblHuyetquy.Text = "Chưa"
		lblHuyetquy.TextColor3 = Color3.fromRGB(239, 68, 68)
	end
end

